import { usePush } from 'pushfire'
import ourPkg from '../../our_pkg.json'

export function usePushNotification() {
  return usePush({
    config: {
      ...ourPkg.firebase,
      serviceWorkerPath: ourPkg.serviceWorker.path,
      registerUrl: ourPkg.backend.registerUrl || undefined,
    },
    onMessage: (message) => {
      console.log('[push] Received background/native message:', message.title)
    },
    onToast: (message) => {
      // Foreground push received while tab is active — plug in your toast library here
      console.log('[push] Active tab message:', message.title, message.body)
      alert(`New Notification: ${message.title}\n${message.body}`)
    },
    onTokenChange: (token) => {
      console.log('[push] Token updated:', token)
    }
  })
}
