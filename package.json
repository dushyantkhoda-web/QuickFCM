{
  "name": "quick-fcm",
  "version": "1.0.0",
  "description": "All-in-one push notification package — npm library + CLI scaffolder with Safari support",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.js"
    }
  },
  "bin": {
    "quick-fcm": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "firebase": ">=10.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "chalk": "^5.0.0",
    "cli-spinners": "^2.9.2",
    "commander": "^11.0.0",
    "firebase": "^12.11.0",
    "ora": "^7.0.1",
    "semver": "^7.6.0"
  },
  "pinnedDeps": {
    "firebase": "12.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "@types/semver": "^7.5.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "firebase",
    "push-notifications",
    "react",
    "fcm",
    "web-push",
    "safari",
    "vapid",
    "service-worker",
    "cli",
    "scaffolder",
    "nestjs",
    "express",
    "QuickFCM"
  ],
  "author": "QuickFCM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dushyantkhoda-web/QuickFCM"
  },
  "homepage": "https://github.com/dushyantkhoda-web/QuickFCM#readme",
  "bugs": {
    "url": "https://github.com/dushyantkhoda-web/QuickFCM/issues"
  }
}
