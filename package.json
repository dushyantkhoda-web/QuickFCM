{
  "name": "custom-push",
  "version": "1.0.2",
  "description": "CustomPush - Firebase push notifications setup tool",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.js"
    }
  },
  "bin": {
    "custom-push": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "src/templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "firebase": ">=10.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "chalk": "^5.0.0",
    "cli-spinners": "^2.9.2",
    "commander": "^11.0.0",
    "ora": "^7.0.1",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "@types/semver": "^7.5.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "firebase",
    "push-notifications",
    "react",
    "fcm",
    "web-push",
    "cli",
    "custompush"
  ],
  "author": "CustomPush Team",
  "license": "MIT"
}
